# ===========================================
# CONFIGURAÇÃO - Agente Financeiro
# Copie este arquivo para .env e atualize valores
# ===========================================

# ============ BANCO DE DADOS ============
# Opções: sqlite (padrão, recomendado) ou postgres (com Docker)
DB_TYPE=sqlite

# SQLite Configuration (Desenvolvimento Local)
SQLITE_PATH=financeiro.db

# PostgreSQL Configuration (Produção com Docker)
DB_HOST=postgres
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=admin_password
DB_NAME=financial_db

# ============ API KEYS ============
# Google Gemini API Key
# Obtenha em: https://aistudio.google.com/app/apikeys
# Deixe vazio se ainda não tem (funcionalidade de IA será limitada)
GEMINI_API_KEY=

# ============ OPCIONAL ============
# Desabilitar coleta de uso do Streamlit
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
